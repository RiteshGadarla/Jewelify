# Jewelify — Git Ignore Rules
# ============================================================

# -------------------------------------------------------------
# Node.js
# -------------------------------------------------------------
node_modules/
/node_modules
/.pnp
.pnp.js

# -------------------------------------------------------------
# Build output
# -------------------------------------------------------------
/build
/dist
dist/
build/

# -------------------------------------------------------------
# Test coverage
# -------------------------------------------------------------
/coverage

# -------------------------------------------------------------
# Logs
# -------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------------------------------------------
# npm / yarn caches
# -------------------------------------------------------------
.npm
.yarn-integrity

# -------------------------------------------------------------
# ESLint cache
# -------------------------------------------------------------
.eslintcache

# -------------------------------------------------------------
# REPL history
# -------------------------------------------------------------
.node_repl_history

# -------------------------------------------------------------
# IDE / Editor files
# -------------------------------------------------------------
.idea/
.vscode/
.DS_Store
.Trash-*

# -------------------------------------------------------------
# Environment configuration (contains secrets — do NOT commit)
# Keep .env.example files (they are safe templates)
# -------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
api/.env
api/model/.env
client/.env
*.env

# -------------------------------------------------------------
# Python virtual environments
# -------------------------------------------------------------
venv/
.venv/
env/
ENV/
api/model/venv/
api/model/venv_test/

# -------------------------------------------------------------
# Python bytecode / cache
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.pytest_cache/

# -------------------------------------------------------------
# Python distribution / packaging
# -------------------------------------------------------------
*.egg-info/
dist/
build/
*.egg

# -------------------------------------------------------------
# ML model weights (large binary files — download separately)
# -------------------------------------------------------------
*.h5
*.pt
*.pth
*.ckpt
*.bin

# -------------------------------------------------------------
# Uploaded / processed / collection image folders
# (runtime output, not source code)
# -------------------------------------------------------------
uploads/
processed/
collection/

# -------------------------------------------------------------
# Jupyter Notebooks checkpoints
# -------------------------------------------------------------
.ipynb_checkpoints/