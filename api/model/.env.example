# Jewelify Flask API Environment Configuration Template
# Copy this file to .env and fill in your actual values.

# Flask Server Configuration
FLASK_PORT=5000
FLASK_DEBUG=True

# App Mode: 'dev' (mock) or 'actual' (ML)
APP_MODE=dev

# Logging Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Storage Paths (relative to api/model/ or absolute)
UPLOAD_FOLDER=./uploads
PROCESSED_FOLDER=./processed
COLLECTION_FOLDER=./collection
MOCK_IMAGES_DIR=./mock_images

# ML Model Configuration (for actual mode)
PIX2PIX_MODEL_PATH=generator.h5
INSTRUCT_PIX2PIX_MODEL_ID=timbrooks/instruct-pix2pix
